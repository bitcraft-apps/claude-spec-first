{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/validate-spec.sh" },
          { "type": "command", "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/validate-implementation.sh" }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "*",
        "hooks": [
          { "type": "command", "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/validate-subagent.sh" }
        ]
      }
    ]
  }
}
